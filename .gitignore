# Dependency directories (if using npm/yarn for packages or build tools)
node_modules/
jspm_packages/
web_modules/

# Production build outputs (if using Vite, Webpack, Parcel, or custom build scripts)
dist/
build/
out/
.cache/
.parcel-cache/

# Local environment variables / Secrets (NEVER commit these!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Logs and runtime data
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids
*.pid
*.seed
*.pid.lock

# Testing & Coverage outputs
coverage/
.nyc_output/

# Linters and IDE formatting caches
.eslintcache
.prettiercache
.DS_Store
Thumbs.db

# Editor-specific folders
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
